# AlumnLink Backend Environment Variables
# 
# This file serves as a template and documentation for environment variables.
# For production, these secrets should be stored in AWS Secrets Manager.
# See AWS_SECRETS_MANAGER_SETUP.md for setup instructions.

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
PORT=4000
NODE_ENV=development

# ==============================================================================
# AWS SECRETS MANAGER CONFIGURATION
# ==============================================================================
# Set to 'true' to use AWS Secrets Manager (automatic in production)
USE_AWS_SECRETS=false

# AWS Credentials (only needed if not using IAM roles)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1

# ==============================================================================
# DATABASE
# ==============================================================================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# ==============================================================================
# AUTHENTICATION
# ==============================================================================
JWT_SECRET=your_jwt_secret_key_here

# ==============================================================================
# EMAIL CONFIGURATION
# ==============================================================================
MAILTRAP_TOKEN=your_mailtrap_token
EMAIL_FROM=noreply@alumnlink.com
EMAIL_FROM_NAME=Team-AlumnLink
ADMIN_EMAILS=admin@alumnlink.com,support@alumnlink.com

# ==============================================================================
# CLOUDINARY (Image Upload Service)
# ==============================================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==============================================================================
# LINKEDIN OAUTH
# ==============================================================================
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=https://api.alumnlink.com/api/v1/auth/linkedinCallback

# ==============================================================================
# URL CONFIGURATION
# ==============================================================================
CLIENT_URL=https://www.alumnlink.com
CLIENT_REDIRECT_URL=https://www.alumnlink.com/
BACKEND_URL=https://api.alumnlink.com/
FRONTEND_URL=https://www.alumnlink.com

# ==============================================================================
# DIGITALOCEAN SPACES (Object Storage)
# ==============================================================================
DO_SPACES_KEY=your_spaces_key
DO_SPACES_SECRET=your_spaces_secret

# ==============================================================================
# NOTES
# ==============================================================================
# 
# SECURITY BEST PRACTICES:
# 1. Never commit .env file with real values to version control
# 2. Use strong, randomly generated secrets for JWT_SECRET
# 3. Use different credentials for development, staging, and production
# 4. Rotate secrets regularly
# 5. Store production secrets in AWS Secrets Manager
# 
# DEVELOPMENT WORKFLOW:
# 1. Copy this file to .env
# 2. Fill in your development credentials
# 3. Run: npm run test-secrets (to verify configuration)
# 4. Run: npm run dev (to start development server)
# 
# PRODUCTION DEPLOYMENT:
# 1. Create secret in AWS Secrets Manager named "alumsecret"
# 2. Set NODE_ENV=production in your deployment environment
# 3. Configure AWS credentials (IAM role preferred)
# 4. Deploy application
# 
# For detailed setup instructions, see:
# - AWS_SECRETS_MANAGER_SETUP.md
# - README.md
